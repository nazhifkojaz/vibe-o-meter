{
  "name": "vibe-o-meter",
  "version": "0.1.3",
  "description": "Terminal tool to visualize AI coding agent usage across OpenCode, Claude Code, Codex, and Pi",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vibe-o-meter": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts"
  },
  "keywords": [
    "ai",
    "coding",
    "agent",
    "stats",
    "heatmap",
    "terminal",
    "vibe-o-meter",
    "vibe"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nazhifkojaz/vibe-stats.git"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.3.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
